# Example ~/.hermes/.env file for hermes-openai-proxy
#
# Copy this file to ~/.hermes/.env and uncomment / fill in the credentials
# you have. The proxy auto-enables any provider whose key is non-empty.
# Lines starting with # are comments; empty values are ignored.

# --- Hermes location (optional override) ---
# HERMES_HOME=/path/to/your/.hermes

# --- Proxy bind (optional) ---
# HERMES_PROXY_HOST=0.0.0.0
# HERMES_PROXY_PORT=8765
# HERMES_PROXY_LOG_LEVEL=info

# --- Diagnostic body dump (set to 1 to dump full request bodies to disk) ---
# HERMES_PROXY_DEBUG_BODIES=

# =============================================================================
# LLM provider credentials. Add at least one.
# =============================================================================

# --- MiniMax (https://minimaxi.com) ---
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_CN_API_KEY=
# MINIMAX_CN_BASE_URL=https://api.minimaxi.com/v1

# --- OpenAI (https://platform.openai.com) ---
# OPENAI_API_KEY=

# --- Anthropic (https://console.anthropic.com) ---
# ANTHROPIC_API_KEY=

# --- Google Gemini (https://aistudio.google.com) ---
# GEMINI_API_KEY=

# --- xAI Grok (https://console.x.ai) ---
# XAI_API_KEY=

# --- OpenRouter (https://openrouter.ai) ---
# OPENROUTER_API_KEY=

# --- Moonshot Kimi (https://platform.moonshot.ai) ---
# KIMI_API_KEY=

# --- Z.ai GLM (https://z.ai) ---
# GLM_API_KEY=

# --- DeepSeek (https://platform.deepseek.com) ---
# DEEPSEEK_API_KEY=

# --- Alibaba DashScope (Qwen) (https://dashscope.aliyun.com) ---
# DASHSCOPE_API_KEY=
# QWEN_API_KEY=

# --- Mistral (https://console.mistral.ai) ---
# MISTRAL_API_KEY=

# --- Xiaomi MiMo (https://xiaomi.ai) ---
# XIAOMI_API_KEY=

# --- Novita (https://novita.ai) ---
# NOVITA_API_KEY=

# --- KiloCode (https://kilocode.ai) ---
# KILOCODE_API_KEY=

# --- OpenCode Zen / Go ---
# OPENCODE_ZEN_API_KEY=
# OPENCODE_GO_API_KEY=

# =============================================================================
# Local providers (no API key required; set the base URL)
# =============================================================================

# --- LM Studio (or any other OpenAI-compat server on localhost) ---
# LM_BASE_URL=http://localhost:1234/v1
# LM_API_KEY=lm-studio

# --- Ollama (with the OpenAI-compat layer enabled) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1

# =============================================================================
# GitHub Copilot (OAuth -- handled by the gh CLI; the proxy just sees a token)
# =============================================================================
# COPILOT_GITHUB_TOKEN=